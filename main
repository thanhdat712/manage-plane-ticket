#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdbool.h>

// --- DATA STRUCTURES ---
typedef struct {
    int day, month, year;
} DATE;

typedef struct {
    int h, m;
} HOUR;

// Structure for flight/plane
typedef struct {
    char ID[10];
    char name[20];
    int seatNormal;
    int seatVIP; 
    int seatHolded;
    int seatVIPHolded;
    char origin[20], destination[20];  
    DATE date;
    HOUR hour;
} Flight;

// Structure for ticket
typedef struct {
    char flightID[10];
    int rank; 
    int ticketID;
    char passengerName[20];
    char seat[5];
    char position[20];
    char origin[20], dest[20];  
    char destination[20];
    long long idCard;
    DATE date;
    HOUR hour;
} Ticket;

// --- LINKED LIST MANAGEMENT ---
// Define Node for flight list
typedef struct NodeFlight { 
    Flight data; 
    struct NodeFlight* next; 
} NodeFlight;

// Define Node for ticket list
typedef struct NodeTicket { 
    Ticket data; 
    struct NodeTicket* next; 
} NodeTicket;

// Declare head pointers for the lists
NodeFlight* headFlight = NULL;
NodeTicket* headTicket = NULL;

// Function to clear input buffer (prevents skipping fgets after scanf)
void clearBuffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}


// --- FLIGHT MANAGEMENT FUNCTIONS ---
// Function to find a flight by ID
NodeFlight* findFlight(char* id) {
    NodeFlight* p = headFlight;
    while (p) { 
        if (strcmp(p->data.ID, id) == 0) 
            return p; 
        p = p->next; 
    }
    return NULL;
}

// Function to add a flight to the system
void addFlight() {
    Flight f;
    printf("\nEnter flight ID: "); 
    scanf("%s", f.ID);
    
    if(findFlight(f.ID)) { 
        printf("ID already exists!\n"); 
        return; 
    }
    clearBuffer(); 
    
    printf("Plane name: "); 
    fgets(f.name, 20, stdin); 
    f.name[strcspn(f.name, "\n")] = 0;
    
    printf("Origin: "); 
    fgets(f.origin, 20, stdin); 
    f.origin[strcspn(f.origin, "\n")] = 0;
    
    printf("Destination: "); 
    fgets(f.destination, 20, stdin); 
    f.destination[strcspn(f.destination, "\n")] = 0;
    
    printf("Normal & VIP seats: "); 
    scanf("%d %d", &f.seatNormal, &f.seatVIP);
    
    f.seatHolded = 0; 
    f.seatVIPHolded = 0;
    
    printf("Date (dd mm yyyy): "); 
    scanf("%d %d %d", &f.date.day, &f.date.month, &f.date.year);
    
    printf("Time (hh mm): "); 
    scanf("%d %d", &f.hour.h, &f.hour.m);
    
    // Allocate memory for new Node and insert at the beginning of the list
    NodeFlight* newNode = (NodeFlight*)malloc(sizeof(NodeFlight));
    newNode->data = f; 
    newNode->next = headFlight; 
    headFlight = newNode;
    
    printf("=> Flight added successfully!\n");
}

// Function to display all flights
void displayFlights() {
    printf("\n%-9s | %-10s | %-12s | %-12s | %-8s | %-8s | %-15s\n", 
           "Flight ID", "Plane", "Origin", "Destination", "N. Seats", "V. Seats", "Departure");
    printf("-----------------------------------------------------------------------------------------------------\n");
    NodeFlight* p = headFlight;
    while(p) {
        printf("%-9s | %-10s | %-12s | %-12s | %d/%-6d | %d/%-6d | %02d:%02d %02d/%02d/%d\n", 
               p->data.ID, p->data.name, p->data.origin, p->data.destination,
               p->data.seatHolded, p->data.seatNormal, 
               p->data.seatVIPHolded, p->data.seatVIP, 
               p->data.hour.h, p->data.hour.m, 
               p->data.date.day, p->data.date.month, p->data.date.year);
        p = p->next;
    }
}

// --- TICKET MANAGEMENT FUNCTIONS ---
// Function to book a ticket

// Helper logic to determine seat label
// Normal: 6 seats per row (a, b, c, d, e, f) -> a1, a2... a6, b1...
// VIP: 4 seats per row (A, B, C, D) -> A1, A2... A4, B1...
void generateSeatLabel(char* buffer, int index, int rank) {
    if (rank == 1) { // VIP
        char row = 'A' + (index / 4);
        int col = (index % 4) + 1;
        sprintf(buffer, "%c%d", row, col);
    } else { // Normal
        char row = 'a' + (index / 6);
        int col = (index % 6) + 1;
        sprintf(buffer, "%c%d", row, col);
    }
}

void bookTicket() {
    char flightID[10];
    int quantity, rank;
    NodeFlight *pNode = NULL;
    //choose plane
    while (1) {
        printf("\nEnter flight ID to book: "); 
        scanf("%s", flightID);
        pNode = findFlight(flightID); // GÁN GIÁ TR? T?I ÐÂY
        
        if (pNode != NULL) break; // Tìm th?y thì thoát vòng l?p
        
        int sel;
        printf("Flight not found!\n1. Retry\n0. Cancel booking\nChoose: ");
        scanf("%d", &sel);
        if (sel == 0) return;
    }
    
    printf("Enter quantity of tickets: "); 
    scanf("%d", &quantity);
    if(quantity <= 0) 
        return;
        
    printf("Seat class (1.VIP - 2.Normal): "); 
    scanf("%d", &rank);
    
    // Check if the plane has enough available seats
    if(rank == 1 && pNode->data.seatVIPHolded + quantity > pNode->data.seatVIP) {
        printf("Not enough VIP seats!\n"); 
        return;
    } else if (rank == 2 && pNode->data.seatHolded + quantity > pNode->data.seatNormal) {
        printf("Not enough Normal seats!\n"); 
        return;
    }
    
    // Loop to enter information for each passenger
    for(int i = 0; i < quantity; i++) {
        printf("\n--- Customer %d ---\n", i + 1);
        Ticket t;
        strcpy(t.flightID, flightID);      
        strcpy(t.origin, pNode->data.origin);
        strcpy(t.dest, pNode->data.destination);
        t.rank = rank;
        t.date = pNode->data.date;      
        t.hour = pNode->data.hour;   
		
		// --- AUTO-GENERATED FIELDS ---
        // Ticket ID: Sequential based on total passengers already on this flight
        // We use (total held + 1) as the new ID
        if (rank == 1) {
            t.ticketID = pNode->data.seatVIPHolded + 1;
            generateSeatLabel(t.seat, pNode->data.seatVIPHolded, rank);
            pNode->data.seatVIPHolded++; // Increment flight counter
        } else {
            t.ticketID = pNode->data.seatHolded + pNode->data.seatVIP + 1;
            generateSeatLabel(t.seat, pNode->data.seatHolded, rank);
            pNode->data.seatHolded++; // Increment flight counter
        }   
         
        printf("ID Card: ");
        scanf("%lld", &t.idCard); 
        clearBuffer();
        
        printf("Passenger name: "); 
        fgets(t.passengerName, 20, stdin); 
        t.passengerName[strcspn(t.passengerName, "\n")] = 0;
        
        // Create new Node and insert at the beginning of the ticket list
        NodeTicket* newNode = (NodeTicket*)malloc(sizeof(NodeTicket));
        newNode->data = t; 
        newNode->next = headTicket; 
        headTicket = newNode;
        
    }
    printf("=> Tickets booked successfully!\n");
}

// Function to display all booked tickets
void displayTickets() {
    printf("\n%-5s | %-13s | %-15s | %-5s | %-9s | %-15s\n", 
           "Ticket ID", "ID Card", "Passenger", "Seat", "Flight ID", "Time");
    printf("--------------------------------------------------------------------------------------------\n");
    NodeTicket* t = headTicket;
    while(t) {
        printf("%-10d | %-13lld | %-15s | %-5s | %-9s | %02d:%02d %02d/%02d/%d\n", 
               t->data.ticketID, t->data.idCard, t->data.passengerName, t->data.seat, t->data.flightID,
               t->data.hour.h, t->data.hour.m, 
               t->data.date.day, t->data.date.month, t->data.date.year);
        t = t->next;
    }
}

// Function to cancel a ticket by Ticket ID
void cancelTicket() {
    int ticketIDToCancel;
    printf("\nEnter ticket ID to cancel: "); 
    scanf("%d", &ticketIDToCancel);
    
    NodeTicket *curr = headTicket, *prev = NULL;
    while(curr) {
        if(curr->data.ticketID == ticketIDToCancel) {
            // Return the seat to the corresponding flight upon cancellation
            NodeFlight* p = findFlight(curr->data.flightID);
            if(p) { 
                if(curr->data.rank == 1) 
                    p->data.seatVIPHolded--; 
                else 
                    p->data.seatHolded--; 
            }
            
            // Remove Node from the linked list
            if(prev == NULL) 
                headTicket = curr->next; 
            else 
                prev->next = curr->next;
                
            free(curr);
            printf("=> Ticket cancelled successfully!\n");
            return;
        }
        prev = curr;
        curr = curr->next;
    }
    printf("Ticket not found!\n");
}

// --- MAIN PROGRAM (MENU) ---
int main() {
    int choice;
    loadData();
    do {
        printf("\n======= FLIGHT MANAGEMENT SYSTEM =======");
        printf("\n1. Add a flight");
        printf("\n2. Display flight list");
        printf("\n3. Book a ticket");
        printf("\n4. Cancel a ticket");
        printf("\n5. Display booked tickets list");
        printf("\n0. Exit program");
        printf("\nChoose an option: ");
        
        // Validate menu input
        if(scanf("%d", &choice) != 1) { 
            clearBuffer(); 
            printf("Please enter numbers only!\n");
            continue; 
        }
        
        switch(choice) {
            case 1: addFlight(); break;
            case 2: displayFlights(); break;
            case 3: bookTicket(); break;
            case 4: cancelTicket(); break;
            case 5: displayTickets(); break;
            case 0: printf("Ending program, Goodbye!\n"); break;
            default: printf("Invalid option! Please try again.\n");
        }
    } while(choice != 0);
    saveData();
    return 0;
}
