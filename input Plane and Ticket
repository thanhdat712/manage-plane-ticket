void addFlight() {
    Flight f;
    printf("\nEnter flight ID: "); 
    scanf("%s", f.ID);
    
    if(findFlight(f.ID)) { 
        printf("ID already exists!\n"); 
        return; 
    }
    clearBuffer(); 
    
    printf("Plane name: "); 
    fgets(f.name, 20, stdin); 
    f.name[strcspn(f.name, "\n")] = 0;
    
    printf("Origin: "); 
    fgets(f.origin, 20, stdin); 
    f.origin[strcspn(f.origin, "\n")] = 0;
    
    printf("Destination: "); 
    fgets(f.destination, 20, stdin); 
    f.destination[strcspn(f.destination, "\n")] = 0;
    
    printf("Normal & VIP seats: "); 
    scanf("%d %d", &f.seatNormal, &f.seatVIP);
    
    f.seatHolded = 0; 
    f.seatVIPHolded = 0;
    
    printf("Date (dd mm yyyy): "); 
    scanf("%d %d %d", &f.date.day, &f.date.month, &f.date.year);
    
    printf("Time (hh mm): "); 
    scanf("%d %d", &f.hour.h, &f.hour.m);
    
    // Allocate memory for new Node and insert at the beginning of the list
    NodeFlight* newNode = (NodeFlight*)malloc(sizeof(NodeFlight));
    newNode->data = f; 
    newNode->next = headFlight; 
    headFlight = newNode;
    
    printf("=> Flight added successfully!\n");
}
void bookTicket() {
    char flightID[10];
    int quantity, rank;
    NodeFlight *pNode = NULL;
    //choose plane
    while (1) {
        printf("\nEnter flight ID to book: "); 
        scanf("%s", flightID);
        pNode = findFlight(flightID); // GÁN GIÁ TR? T?I ?ÂY
        if (pNode != NULL) break; // T?m th?y th? thoát v?ng l?p
        int sel;
        printf("Flight not found!\n1. Retry\n0. Cancel booking\nChoose: ");
        scanf("%d", &sel);
        if (sel == 0) return;
    }
    printf("Enter quantity of tickets: "); 
    scanf("%d", &quantity);
    if(quantity <= 0) 
        return;
    printf("Seat class (1.VIP - 2.Normal): "); 
    scanf("%d", &rank);
    // Check if the plane has enough available seats
    if(rank == 1 && pNode->data.seatVIPHolded + quantity > pNode->data.seatVIP) {
        printf("Not enough VIP seats!\n"); 
        return;
    } else if (rank == 2 && pNode->data.seatHolded + quantity > pNode->data.seatNormal) {
        printf("Not enough Normal seats!\n"); 
        return;
    }
    // Loop to enter information for each passenger
    for(int i = 0; i < quantity; i++) {
        printf("\n--- Customer %d ---\n", i + 1);
        Ticket t;
        strcpy(t.flightID, flightID);      
        strcpy(t.origin, pNode->data.origin);
        strcpy(t.dest, pNode->data.destination);
        t.rank = rank;
        t.date = pNode->data.date;      
        t.hour = pNode->data.hour;   
		
		// --- AUTO-GENERATED FIELDS ---
        // Ticket ID: Sequential based on total passengers already on this flight
        // We use (total held + 1) as the new ID
        if (rank == 1) {
            t.ticketID = pNode->data.seatVIPHolded + 1;
            generateSeatLabel(t.seat, pNode->data.seatVIPHolded, rank);
            pNode->data.seatVIPHolded++; // Increment flight counter
        } else {
            t.ticketID = pNode->data.seatHolded + pNode->data.seatVIP + 1;
            generateSeatLabel(t.seat, pNode->data.seatHolded, rank);
            pNode->data.seatHolded++; // Increment flight counter
        }   
         
        printf("ID Card: ");
        scanf("%lld", &t.idCard); 
        clearBuffer();
        
        printf("Passenger name: "); 
        fgets(t.passengerName, 20, stdin); 
        t.passengerName[strcspn(t.passengerName, "\n")] = 0;
        
        // Create new Node and insert at the beginning of the ticket list
        NodeTicket* newNode = (NodeTicket*)malloc(sizeof(NodeTicket));
        newNode->data = t; 
        newNode->next = headTicket; 
        headTicket = newNode;
        
    }
    printf("=> Tickets booked successfully!\n");
}
